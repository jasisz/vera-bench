-- VeraBench VB-T3-005: Tree Sum
-- Sum all leaf values in a binary tree.
private data Tree {
  Leaf(Int),
  Branch(Tree, Tree)
}

public fn tree_sum(@Tree -> @Int)
  requires(true)
  ensures(true)
  decreases(@Tree.0)
  effects(pure)
{
  match @Tree.0 {
    Leaf(@Int) -> @Int.0,
    Branch(@Tree, @Tree) -> tree_sum(@Tree.1) + tree_sum(@Tree.0)
  }
}
