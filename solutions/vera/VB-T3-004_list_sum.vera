-- VeraBench VB-T3-004: List Sum
-- Sum all elements in a linked list.
private data List {
  Nil,
  Cons(Int, List)
}

public fn list_sum(@List -> @Int)
  requires(true)
  ensures(true)
  decreases(@List.0)
  effects(pure)
{
  match @List.0 {
    Nil -> 0,
    Cons(@Int, @List) -> @Int.0 + list_sum(@List.0)
  }
}
