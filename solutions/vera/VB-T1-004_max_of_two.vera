-- VeraBench VB-T1-004: Maximum of Two
-- Return the larger of two integers.
-- Parameters: max_of_two(a, b) where @Int.0 = b, @Int.1 = a
public fn max_of_two(@Int, @Int -> @Int)
  requires(true)
  ensures(@Int.result >= @Int.1)
  ensures(@Int.result >= @Int.0)
  ensures(@Int.result == @Int.1 || @Int.result == @Int.0)
  effects(pure)
{
  if @Int.1 >= @Int.0 then {
    @Int.1
  } else {
    @Int.0
  }
}
