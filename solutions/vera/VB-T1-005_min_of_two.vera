-- VeraBench VB-T1-005: Minimum of Two
-- Return the smaller of two integers.
-- Parameters: min_of_two(a, b) where @Int.0 = b, @Int.1 = a
public fn min_of_two(@Int, @Int -> @Int)
  requires(true)
  ensures(@Int.result <= @Int.1)
  ensures(@Int.result <= @Int.0)
  ensures(@Int.result == @Int.1 || @Int.result == @Int.0)
  effects(pure)
{
  if @Int.1 <= @Int.0 then {
    @Int.1
  } else {
    @Int.0
  }
}
