-- VeraBench VB-T1-003: Signum
-- Return -1, 0, or 1 depending on the sign of the input.
public fn signum(@Int -> @Int)
  requires(true)
  ensures(@Int.result == -1 || @Int.result == 0 || @Int.result == 1)
  effects(pure)
{
  if @Int.0 > 0 then {
    1
  } else {
    if @Int.0 < 0 then {
      -1
    } else {
      0
    }
  }
}
