-- VeraBench VB-T2-008: Count Positives
-- Count the number of positive elements in an integer array.
public fn count_positives(@Array<Int> -> @Nat)
  requires(true)
  ensures(@Nat.result >= 0)
  effects(pure)
{
  array_length(array_filter(@Array<Int>.0, fn(@Int -> @Bool) effects(pure) { @Int.0 > 0 }))
}
